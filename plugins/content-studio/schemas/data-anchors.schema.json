{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "data-anchors",
  "description": "Single source of truth for a year-stamped reference dataset (e.g. a 一分一段 分数→位次 table). Content cites these anchors in prose via the 「分数≈位次万」form; scripts/check-freshness.mjs verifies those citations against this file and flags a stale data_year. Record `source` honestly (name + real URL) — never fabricate the numbers.",
  "type": "object",
  "required": ["dataset_id", "data_year", "source", "anchors"],
  "properties": {
    "dataset_id": { "type": "string", "minLength": 1 },
    "data_year": { "type": "integer" },
    "region": { "type": "string" },
    "category": { "type": "string" },
    "unit": { "type": "string" },
    "source": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "url": { "type": "string" },
        "retrieved": { "type": "string" }
      }
    },
    "anchors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["score", "rank", "rank_wan"],
        "properties": {
          "score": { "type": "integer" },
          "rank": { "type": "integer" },
          "rank_wan": { "type": "number" }
        }
      }
    }
  }
}
