# Content Studio — environment template.
# Copy to .env in YOUR content workspace and fill in. Nothing here is required to run the
# core pipeline (research → draft → review → publish-gate); the gates are zero-dependency.
#
# Optional: override where the gates look for your content (defaults to the current directory).
# CONTENT_STUDIO_ROOT=/absolute/path/to/your/content-workspace

# Optional: API keys for richer keyword research (the default web-search path needs none).
# Never commit a real key — this file is a template; keep your real .env gitignored.
# AHREFS_API_TOKEN=
# DATAFORSEO_LOGIN=
# DATAFORSEO_PASSWORD=
